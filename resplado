<!-- Backdrop -->
<div class="ol-backdrop" *ngIf="open" aria-hidden="true"></div>

<!-- Panel -->
<section
  *ngIf="open"
  #panel
  class="ol-panel"
  role="dialog"
  aria-modal="true"
  aria-label="Búsqueda Más Latino"
  (click)="$event.stopPropagation()" 
>
  <!-- Top: input + close -->
  <div class="ol-row ol-top">
    <div class="ol-input-wrap">
      <span class="ol-icon">⌘K</span>
      <input #searchInput
             type="text"
             [(ngModel)]="query"
             (input)="onQueryChange()"
             placeholder="Buscar noticias, podcasts, categorías…"
             aria-label="Buscar"
             class="ol-input" />
      <button class="ol-close" (click)="close()" aria-label="Cerrar">Esc</button>
    </div>
  </div>

  <!-- Quick actions: your sections -->
  <div class="ol-row ol-quick">
    <a *ngFor="let q of quickLinks"
       class="ol-quick-item"
       [routerLink]="q.route"
       (click)="close()">
      <span class="ol-qi-icon">{{q.icon}}</span>
      <span class="ol-qi-label">{{q.label}}</span>
    </a>
  </div>

  <!-- Filters -->
  <div class="ol-row ol-filters" role="tablist" aria-label="Filtros">
    <button class="ol-chip" [class.active]="activeSection==='todo'" (click)="setSection('todo')" role="tab">Todo</button>
    <button class="ol-chip" [class.active]="activeSection==='quienes'" (click)="setSection('quienes')" role="tab">¿Quiénes Somos?</button>
    <button class="ol-chip" [class.active]="activeSection==='categorias'" (click)="setSection('categorias')" role="tab">Categorias</button>
    <button class="ol-chip" [class.active]="activeSection==='podcast'" (click)="setSection('podcast')" role="tab">Podcast</button>
    <button class="ol-chip" [class.active]="activeSection==='locales'" (click)="setSection('locales')" role="tab">Locales</button>
    <button class="ol-chip" [class.active]="activeSection==='contacto'" (click)="setSection('contacto')" role="tab">Contacto</button>
    <button class="ol-chip" [class.active]="activeSection==='privacy'" (click)="setSection('privacy')" role="tab">Privacy</button>
  </div>

  <!-- Empty state (no typing) -->
  <div class="ol-row ol-empty" *ngIf="!showResults">
    <div class="ol-col">
      <h4>Buscar por…</h4>
      <ul class="ol-list">
        <li>Temas (p. ej. <em>tecnología</em>, <em>cultura</em>)</li>
        <li>Podcast (p. ej. <em>Voces de la Comunidad</em>)</li>
        <li>Noticias locales</li>
        <li>Secciones del sitio</li>
      </ul>
    </div>
    <div class="ol-col">
      <h4>Recientes</h4>
      <div class="ol-recents">
        <button *ngFor="let r of recent" (click)="useRecent(r)" class="ol-recent">{{r}}</button>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div class="ol-row ol-results" *ngIf="showResults">
    <div *ngIf="!filtered.length" class="ol-empty-mini">
      Sin resultados para “{{query}}”.
    </div>

    <a *ngFor="let item of filtered; let i = index"
       class="ol-result"
       [id]="'result-' + i"
       [class.highlight]="i === highlightedIndex"
       [routerLink]="item.route"
       (click)="pick(item)">
      <div class="ol-result-icon">🔎</div>
      <div class="ol-result-main">
        <div class="ol-result-title">{{ item.title }}</div>
        <div class="ol-result-meta">{{ item.section }}</div>
      </div>
      <div class="ol-result-go">↵</div>
    </a>
  </div>

  <!-- Footer hint -->
  <footer class="ol-footer">
    <span><b>Enter</b> abrir · <b>↑/↓</b> navegar · <b>Esc</b> cerrar</span>
  </footer>
</section>
